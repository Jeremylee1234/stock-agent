# 环境配置
ENVIRONMENT=production

# ===== 必需配置 =====
# DeepSeek API Key（必需）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ===== 可选配置 =====

# OpenAI API Key（可选，用于备用模型）
OPENAI_API_KEY=

# 搜索API（可选）
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# ===== 数据源配置 =====

# Tushare Pro
DATA_SOURCE__TUSHARE_TOKEN=your-tushare-token
DATA_SOURCE__TUSHARE_TIMEOUT=30
DATA_SOURCE__TUSHARE_RETRY_COUNT=3

# iFinD 量化 API（超级命令 → 工具 → refresh_token 查询）
IFIND_REFRESH_TOKEN=
DATA_SOURCE__IFIND_REFRESH_TOKEN=

# 数据源优先级
DATA_SOURCE__DATA_SOURCE_PRIORITY=ifind,tushare

# ===== 缓存配置 =====
CACHE__ENABLE_CACHE=true
CACHE__CACHE_DIR=data_cache
CACHE__CACHE_TTL=3600
CACHE__MAX_CACHE_SIZE_MB=1000

# ===== 日志配置 =====
LOG__LOG_LEVEL=INFO
LOG__LOG_DIR=logs
LOG__LOG_TO_CONSOLE=true
LOG__LOG_TO_FILE=true

# ===== 性能配置 =====
PERFORMANCE__MAX_CONCURRENT_REQUESTS=10
PERFORMANCE__REQUEST_TIMEOUT=300
PERFORMANCE__MAX_MESSAGE_HISTORY=30

# ===== LLM配置 =====
LLM__DEFAULT_MODEL=deepseek-chat
LLM__TEMPERATURE=0.7
LLM__TIMEOUT=60

# ===== API配置 =====
API__HOST=0.0.0.0
API__PORT=8000
API__CORS_ORIGINS=*
API__ENABLE_DOCS=true
